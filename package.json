{
  "name": "netcdf-gcms",
  "version": "3.0.0",
  "description": "Parser from NetCDF files to JSON usable for GC/MS",
  "type": "module",
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "default": "./lib/index.js"
    }
  },
  "files": [
    "lib",
    "src"
  ],
  "scripts": {
    "build": "npm run tsc && cheminfo-build --entry lib/index.js --root NetCDFgcms",
    "check-types": "tsc --noEmit",
    "clean": "rimraf lib",
    "eslint": "eslint src",
    "eslint-fix": "npm run eslint -- --fix",
    "prepack": "npm run tsc",
    "prettier": "prettier --check src",
    "prettier-write": "prettier --write src",
    "test": "npm run test-only && npm run check-types && npm run eslint && npm run prettier",
    "test-only": "vitest run --coverage",
    "tsc": "npm run clean && tsc -p tsconfig.build.json"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/cheminfo/netcdf-gcms.git"
  },
  "keywords": [
    "cheminfo",
    "chemistry",
    "netcdf",
    "gcms",
    "chromatography"
  ],
  "author": "Miguel Asencio <maasencioh@gmail.com>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/cheminfo/netcdf-gcms/issues"
  },
  "homepage": "https://github.com/cheminfo/netcdf-gcms#readme",
  "dependencies": {
    "netcdfjs": "^3.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.3.5",
    "@vitest/coverage-v8": "^4.0.18",
    "@zakodium/tsconfig": "^1.0.2",
    "cheminfo-build": "^1.3.2",
    "eslint": "^9.15.0",
    "eslint-config-cheminfo-typescript": "^21.1.0",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.3",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
